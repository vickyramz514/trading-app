PORT=3002

# Zerodha Kite Connect (https://kite.trade/)
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:3002/api/kite/callback

# For OAuth redirect - frontend URL after login
