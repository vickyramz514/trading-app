PORT=3002

# Broker API (set for your broker: Zerodha/Angel One/Upstox)
BROKER_API_KEY=
BROKER_ACCESS_TOKEN=
BROKER_BASE_URL=

# Optional: customize broker API paths (defaults in config)
# BROKER_PATH_PROFILE=/user/profile
# BROKER_PATH_HOLDINGS=/portfolio/holdings
# BROKER_PATH_POSITIONS=/portfolio/positions
# BROKER_PATH_QUOTE=/market/quote

# JWT for optional auth (change in production)
JWT_SECRET=your-secret-key
